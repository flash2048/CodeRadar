<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Project-local NuGet configuration.
    <clear /> wipes any package sources inherited from parent NuGet.Config files
    (e.g. corporate Artifactory feeds in %AppData%\NuGet\NuGet.Config or higher-up
    directories) so this project always restores from nuget.org regardless of the
    machine it's built on.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <clear />
  </packageSourceMapping>
</configuration>
