<Window x:Class="CodeRadar.Views.CompareSnapshotsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
        Title="Compare snapshots"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#F1F1F1"
        FontFamily="{DynamicResource {x:Static vs:VsFonts.EnvironmentFontFamilyKey}}"
        FontSize="{DynamicResource {x:Static vs:VsFonts.EnvironmentFontSizeKey}}">

    <Window.Resources>
        <SolidColorBrush x:Key="Border" Color="#3F3F46" />
        <SolidColorBrush x:Key="Muted"  Color="#7A7A7A" />
        <SolidColorBrush x:Key="Accent" Color="#FFC83D" />
        <SolidColorBrush x:Key="Changed" Color="#33FFC83D" />
        <SolidColorBrush x:Key="Added"   Color="#334EC9B0" />
        <SolidColorBrush x:Key="Removed" Color="#33F48771" />
    </Window.Resources>

    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Left:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource Muted}" />
                <ComboBox x:Name="LeftCombo" Width="280"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ComboChanged" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="Right:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource Muted}" />
                <ComboBox x:Name="RightCombo" Width="280"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ComboChanged" />
                <TextBlock x:Name="DiffSummary" Margin="16,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource Accent}" />
            </StackPanel>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,4,0">
                <TreeView x:Name="LeftTree" Background="Transparent" BorderThickness="0"
                          Foreground="#F1F1F1" Padding="4" />
            </Border>
            <Border Grid.Column="1" BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="4,0,0,0">
                <TreeView x:Name="RightTree" Background="Transparent" BorderThickness="0"
                          Foreground="#F1F1F1" Padding="4" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
