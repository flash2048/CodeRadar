<Window x:Class="CodeRadar.Views.WatchHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
        Title="Watch History"
        Width="640" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#F1F1F1"
        FontFamily="{DynamicResource {x:Static vs:VsFonts.EnvironmentFontFamilyKey}}"
        FontSize="{DynamicResource {x:Static vs:VsFonts.EnvironmentFontSizeKey}}">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#FFC83D" />
        <SolidColorBrush x:Key="Muted"  Color="#7A7A7A" />
        <SolidColorBrush x:Key="RowAlt" Color="#161616" />
    </Window.Resources>

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock x:Name="HeaderText" FontSize="14" FontWeight="Bold" />
            <TextBlock x:Name="SubText" Foreground="{StaticResource Muted}" Margin="0,2,0,0" />
        </StackPanel>

        <ListView x:Name="HistoryList" Background="Transparent" BorderBrush="#3F3F46"
                  AlternationCount="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Break" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding BreakIndex, StringFormat=#{0}}"
                                           Padding="6,2"
                                           Foreground="{StaticResource Muted}"
                                           HorizontalAlignment="Right" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Time" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayTime}" Padding="6,2"
                                           Foreground="#B5B5B5" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Δ" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Padding="6,2" HorizontalAlignment="Center"
                                           FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="" />
                                            <Setter Property="Foreground" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Changed}" Value="True">
                                                    <Setter Property="Text" Value="●" />
                                                    <Setter Property="Foreground" Value="{StaticResource Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Value" Width="380">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" Padding="6,2"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Value}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#F1F1F1" />
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="{StaticResource RowAlt}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding Changed}" Value="True">
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</Window>
