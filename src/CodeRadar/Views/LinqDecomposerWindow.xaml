<Window x:Class="CodeRadar.Views.LinqDecomposerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
        Title="LINQ Chain Decomposer"
        Width="820" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#F1F1F1"
        FontFamily="{DynamicResource {x:Static vs:VsFonts.EnvironmentFontFamilyKey}}"
        FontSize="{DynamicResource {x:Static vs:VsFonts.EnvironmentFontSizeKey}}">

    <Window.Resources>
        <SolidColorBrush x:Key="Border" Color="#3F3F46" />
        <SolidColorBrush x:Key="Muted"  Color="#7A7A7A" />
        <SolidColorBrush x:Key="Accent" Color="#FFC83D" />
        <SolidColorBrush x:Key="Type"   Color="#7AC97A" />
        <SolidColorBrush x:Key="Name"   Color="#9CDCFE" />
        <SolidColorBrush x:Key="Danger" Color="#F48771" />
        <SolidColorBrush x:Key="RowAlt" Color="#161616" />

        <!-- Recursive template for VariableNode children -->
        <HierarchicalDataTemplate x:Key="VariableNodeTemplate"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                           Foreground="{StaticResource Name}" />
                <TextBlock Text=" = " Foreground="{StaticResource Muted}" />
                <TextBlock Text="{Binding Value}" />
                <TextBlock Text=" : " Foreground="{StaticResource Muted}"
                           Margin="6,0,0,0" />
                <TextBlock Text="{Binding Type}" Foreground="{StaticResource Type}" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Original expression" Foreground="{StaticResource Muted}" />
            <TextBox x:Name="OriginalExprBox" IsReadOnly="True" Margin="0,2,0,0"
                     Background="#252526" Foreground="#F1F1F1" BorderBrush="{StaticResource Border}"
                     FontFamily="Consolas" Padding="4" />
        </StackPanel>

        <ListView x:Name="StepList" Background="Transparent" BorderBrush="{StaticResource Border}"
                  AlternationCount="2">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="{StaticResource RowAlt}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="#22000000">
                        <StackPanel>
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Background="{StaticResource Accent}"
                                        CornerRadius="2" Padding="6,2" Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StepNumber}" FontWeight="Bold"
                                               Foreground="#1E1E1E" />
                                </Border>
                                <TextBlock Text="{Binding Result.Label}" FontFamily="Consolas"
                                           FontWeight="SemiBold" Foreground="{StaticResource Name}"
                                           VerticalAlignment="Center" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding CountText}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{StaticResource Accent}" FontWeight="Bold" />
                            </DockPanel>
                            <TextBlock Text="{Binding Result.CumulativeExpression}"
                                       FontFamily="Consolas" Foreground="{StaticResource Muted}"
                                       Margin="0,4,0,0" TextWrapping="Wrap" />

                            <!-- Error -->
                            <Border Visibility="{Binding HasErrorVisibility}" Margin="0,6,0,0"
                                    Background="#33F48771" BorderBrush="{StaticResource Danger}"
                                    BorderThickness="1" CornerRadius="2" Padding="6">
                                <TextBlock Text="{Binding Result.Error}" Foreground="{StaticResource Danger}" />
                            </Border>

                            <!-- Sample items as expandable tree -->
                            <TreeView x:Name="SampleTree"
                                      ItemsSource="{Binding Result.SampleItems}" Margin="8,6,0,0"
                                      Visibility="{Binding HasSamplesVisibility}"
                                      Background="Transparent" BorderThickness="0"
                                      ItemTemplate="{StaticResource VariableNodeTemplate}">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Foreground" Value="#F1F1F1" />
                                        <Setter Property="IsExpanded" Value="False" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="View / Export object..."
                                                  Click="ViewObject_Click" />
                                        <MenuItem Header="Show image..."
                                                  Click="ShowImage_Click" />
                                        <Separator />
                                        <MenuItem Header="Copy value"
                                                  Click="CopyValue_Click" />
                                        <MenuItem Header="Copy as JSON"
                                                  Click="CopyAsJson_Click" />
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                            </TreeView>
                            <TextBlock Text="... more elements not shown (truncated at 50)"
                                       Foreground="{StaticResource Muted}" Margin="16,4,0,0"
                                       FontStyle="Italic"
                                       Visibility="{Binding TruncatedVisibility}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</Window>
