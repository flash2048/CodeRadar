<Window x:Class="CodeRadar.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
        Title="Image Viewer"
        Width="860" Height="620"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1E1E1E"
        Foreground="#F1F1F1"
        FontFamily="{DynamicResource {x:Static vs:VsFonts.EnvironmentFontFamilyKey}}"
        FontSize="{DynamicResource {x:Static vs:VsFonts.EnvironmentFontSizeKey}}">

    <Window.Resources>
        <SolidColorBrush x:Key="Fg"       Color="#F1F1F1" />
        <SolidColorBrush x:Key="Muted"    Color="#B5B5B5" />
        <SolidColorBrush x:Key="Border"   Color="#3F3F46" />
        <SolidColorBrush x:Key="BgPanel"  Color="#252526" />
        <SolidColorBrush x:Key="Accent"   Color="#FFC83D" />
        <SolidColorBrush x:Key="BgHover"  Color="#3F3F46" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgHover}" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505056" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,10"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Border Background="{StaticResource Accent}" CornerRadius="2" Padding="6,2">
                        <TextBlock x:Name="FormatBadge" FontWeight="Bold" Foreground="#1E1E1E" />
                    </Border>
                    <TextBlock x:Name="InfoText" Foreground="{StaticResource Muted}"
                               Margin="12,0,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource Accent}"
                               FontStyle="Italic" Margin="0,0,12,0" />
                    <Button Content="Copy" Click="CopyButton_Click" />
                    <Button Content="Save As…" Click="SaveButton_Click" Margin="8,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Image surface -->
        <Border Margin="0,10,0,0" BorderBrush="{StaticResource Border}" BorderThickness="1"
                Background="#121212">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- Subtle checkerboard-ish fill so transparent images are visible -->
                    <Rectangle Fill="#181818" />
                    <Image x:Name="ImageControl" Stretch="None"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="8" />
                </Grid>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
