  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="'$(VSToolsPath)' != ''" />
  <!--
    Auto-generate marketplace assets (icon.png, preview.png, hero.png) from
    tools\Generate-Assets.ps1 when any of them is missing. Runs once, caches
    afterwards; delete a PNG and rebuild to re-generate.
  -->
  <Target Name="GenerateMarketplaceAssets" BeforeTargets="PrepareForBuild" Condition="!Exists('$(MSBuildProjectDirectory)\assets\icon.png') Or&#xA;                     !Exists('$(MSBuildProjectDirectory)\assets\preview.png') Or&#xA;                     !Exists('$(MSBuildProjectDirectory)\assets\hero.png') Or&#xA;                     !Exists('$(MSBuildProjectDirectory)\Resources\CommandIcons.png')">
    <Message Importance="high" Text="Code Radar: generating marketplace + command-icon assets ..." />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\..\..\tools\Generate-Assets.ps1&quot; -OutDir &quot;$(MSBuildProjectDirectory)\assets&quot;" WorkingDirectory="$(MSBuildProjectDirectory)" IgnoreExitCode="false" />
  </Target>
