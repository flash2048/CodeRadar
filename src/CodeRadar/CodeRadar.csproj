  <ItemGroup>
    <!--
      Marketplace assets. Icon and PreviewImage are referenced from
      source.extension.vsixmanifest and must be packed into the VSIX.
      The hero image is not in the VSIX but lives alongside for convenience.
      If any of these files are missing at build time, the GenerateAssets
      target (below) regenerates them from tools\Generate-Assets.ps1.
    -->
    <Content Include="assets\icon.png">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="assets\preview.png">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <None Include="assets\hero.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
